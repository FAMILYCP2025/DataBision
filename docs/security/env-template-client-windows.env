# DataBision Extractor — Variables de entorno (Windows Server)
# =============================================================
# INSTRUCCIONES:
# 1. Copiar este archivo a C:\DataBision\Extractor\.env
# 2. Completar todos los valores marcados con <REEMPLAZAR>
# 3. Restringir permisos: solo el usuario de servicio puede leer este archivo
#    (icacls ".env" /inheritance:r /grant "DATABISION_SVC:(R)")
# 4. NUNCA subir este archivo a un repositorio de codigo
# 5. Cargar antes de ejecutar el extractor:
#    Get-Content .env | ForEach-Object {
#      if ($_ -match '^([^#][^=]+)=(.*)$') {
#        [System.Environment]::SetEnvironmentVariable($Matches[1], $Matches[2], 'Process')
#      }
#    }

ASPNETCORE_ENVIRONMENT=Production

# Contrasena SAP Service Layer del cliente
# Referenciada en el perfil de conexion como: env:SAP_PASSWORD_CLIENTE
SAP_PASSWORD_CLIENTE=<REEMPLAZAR>

# API Key para enviar datos al endpoint de ingest de DataBision
DataBisionApi__ApiKey=<REEMPLAZAR>

# Connection string de Supabase (para transform local si aplica)
# Usar port 6543 para operacion normal, 5432 solo para migrations
Staging__ConnectionString=<REEMPLAZAR>
